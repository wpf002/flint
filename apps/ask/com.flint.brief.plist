<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Flint morning brief (macOS LaunchAgent). Installed by apps/ask/install-nightly.sh.
  Points at ~/.flint (NOT the repo) — macOS TCC blocks launchd from ~/Documents.

  Run once now: launchctl kickstart -k gui/$(id -u)/com.flint.brief
  Uninstall:    launchctl unload -w ~/Library/LaunchAgents/com.flint.brief.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.flint.brief</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/willfoti/.flint/morning-brief.sh</string>
  </array>

  <!-- 07:00 daily. If asleep, runs at next wake. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/willfoti/.flint/launchd-brief.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/willfoti/.flint/launchd-brief.err.log</string>
</dict>
</plist>
