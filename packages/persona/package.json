{
  "name": "@flint/persona",
  "version": "0.1.0",
  "description": "Your AI's identity layer on top of @flint/core — style guide + retrieval of your own writing. Provider-agnostic.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@flint/core": "workspace:*"
  },
  "devDependencies": {
    "@flint/core": "workspace:*",
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
